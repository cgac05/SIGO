# Configuración FINAL de ODBC - Simple y definitiva
# Problema: ODBC Driver 18 rechaza certificados de RDS
# Solución: Configurar ODBC para confiar SIEMPRE en certificados

files:
  "/etc/odbc.ini":
    mode: "000644"
    owner: root
    group: root
    content: |
      [SIGO-RDS]
      Driver=ODBC Driver 18 for SQL Server
      Server=bdsigoprod.ca7cms0eernu.us-east-1.rds.amazonaws.com,1433
      Database=BD_SIGO
      TrustServerCertificate=yes
      Encrypt=yes
      Connection Timeout=30

  "/etc/odbcinst.ini":
    mode: "000644"
    owner: root
    group: root
    content: |
      [ODBC Driver 18 for SQL Server]
      Description=Microsoft ODBC Driver 18 for SQL Server
      Driver=libodbcsqlsrv.so.18.3
      UsageCount=1

commands:
  01_create_log_dir:
    command: |
      mkdir -p /var/app/current/storage/logs/eb_fixes
      chmod 755 /var/app/current/storage/logs/eb_fixes
      chown -R webapp:webapp /var/app/current/storage/logs/eb_fixes 2>/dev/null || true

  02_test_odbc_connection:
    command: |
      echo "=== Test ODBC Connection ===" > /tmp/odbc_final_test.log 2>&1
      
      # Test con PHP
      php << 'PHPEOF' >> /tmp/odbc_final_test.log 2>&1
<?php
$serverName = "bdsigoprod.ca7cms0eernu.us-east-1.rds.amazonaws.com,1433";
$database = "BD_SIGO";
$username = "admin";
$password = "vv8StWVd9Rx8JVc?";

try {
    $connectionString = "sqlsrv:Server=$serverName;Database=$database;Encrypt=yes;TrustServerCertificate=yes";
    
    echo "Intentando conexión SQL Server...\n";
    $pdo = new PDO($connectionString, $username, $password);
    
    $result = $pdo->query("SELECT 1 as test");
    $row = $result->fetch(PDO::FETCH_ASSOC);
    
    echo "✓ ÉXITO: Conexión establecida\n";
    echo "Test query: " . json_encode($row) . "\n";
    exit(0);
    
} catch (PDOException $e) {
    echo "✗ FALLO: " . $e->getMessage() . "\n";
    exit(1);
}
PHPEOF
      
      cp /tmp/odbc_final_test.log /var/app/current/storage/logs/eb_fixes/ 2>/dev/null || true

  03_clear_and_cache:
    command: |
      cd /var/app/current
      php artisan config:clear 2>&1 | tee /tmp/cache.log
      php artisan cache:clear 2>&1 | tee -a /tmp/cache.log
      php artisan config:cache 2>&1 | tee -a /tmp/cache.log
      cp /tmp/cache.log /var/app/current/storage/logs/eb_fixes/ 2>/dev/null || true

  04_restart_services:
    command: |
      systemctl restart php-fpm 2>&1 | tee /tmp/restart.log
      systemctl restart nginx 2>&1 | tee -a /tmp/restart.log
      sleep 2
      cp /tmp/restart.log /var/app/current/storage/logs/eb_fixes/ 2>/dev/null || true

option_settings:
  aws:elasticbeanstalk:application:environment:
    DB_ENCRYPT: "yes"
    DB_TRUST_SERVER_CERTIFICATE: "true"
    DB_LOGIN_TIMEOUT: "30"
