# Configurar APP_URL automáticamente basado en el endpoint de EB
# También regenerar cache de configuración después de cambios

commands:
  01_detect_eb_endpoint:
    command: |
      # Detectar el endpoint de EB automáticamente
      EB_ENDPOINT=$(ec2-metadata --public-hostname 2>/dev/null | cut -d " " -f 2 || echo "")
      
      # Si no se obtiene con ec2-metadata, intentar con curl
      if [ -z "$EB_ENDPOINT" ] || [ "$EB_ENDPOINT" = "localhost" ]; then
        EB_ENDPOINT=$(curl -s http://169.254.169.254/latest/meta-data/public-hostname || echo "")
      fi
      
      # Fallback: leer del .elasticbeanstalk/config.yml si existe
      if [ -z "$EB_ENDPOINT" ] || [ "$EB_ENDPOINT" = "localhost" ]; then
        EB_ENDPOINT=$(grep "cname:" /var/app/current/.elasticbeanstalk/config.yml 2>/dev/null | awk '{print $2}' || echo "")
      fi
      
      # Si aún no tenemos endpoint, usar el nombre del ambiente
      if [ -z "$EB_ENDPOINT" ] || [ "$EB_ENDPOINT" = "localhost" ]; then
        EB_ENV=$(curl -s http://169.254.169.254/latest/meta-data/tags/instance:elasticbeanstalk:environment-name 2>/dev/null || echo "")
        if [ -n "$EB_ENV" ]; then
          EB_ENDPOINT="${EB_ENV}.eba-pjwh8vad.us-east-1.elasticbeanstalk.com"
        fi
      fi
      
      echo "EB_ENDPOINT=$EB_ENDPOINT" > /tmp/eb_endpoint.env
      echo "Endpoint detectado: $EB_ENDPOINT"

  02_update_app_url:
    command: |
      source /tmp/eb_endpoint.env
      
      if [ -n "$EB_ENDPOINT" ] && [ "$EB_ENDPOINT" != "localhost" ]; then
        APP_URL="https://${EB_ENDPOINT}"
        echo "Actualizando APP_URL a: $APP_URL"
        
        # Actualizar .env (asegurar que esté en la forma correcta)
        sed -i "s|^APP_URL=.*|APP_URL=${APP_URL}|g" /var/app/current/.env
        
        # Verificar que se actualizó
        grep "APP_URL=" /var/app/current/.env
      else
        echo "⚠ No se pudo detectar EB endpoint, manteniendo APP_URL actual"
        grep "APP_URL=" /var/app/current/.env
      fi

  03_regenerate_laravel_config_cache:
    command: |
      cd /var/app/current
      
      # Limpiar caches anteriores
      php artisan config:clear 2>&1 | tee /tmp/config_clear.log
      php artisan view:clear 2>&1 | tee /tmp/view_clear.log
      
      # Regenerar caches para producción
      php artisan config:cache 2>&1 | tee /tmp/config_cache.log
      php artisan view:cache 2>&1 | tee /tmp/view_cache.log
      php artisan route:cache 2>&1 | tee /tmp/route_cache.log || echo "⚠ Route cache puede no ser necesario"
      
      echo "✓ Caches de Laravel regenerados"

  04_verify_app_url:
    command: |
      cd /var/app/current
      
      # Mostrar APP_URL actual
      echo "=== VERIFICACIÓN APP_URL ===" > /tmp/app_url_verify.log
      grep "APP_URL=" /var/app/current/.env >> /tmp/app_url_verify.log
      
      # Verificar en la configuración PHP
      php -r "require 'bootstrap/app.php'; echo 'APP_URL en config: ' . config('app.url');" >> /tmp/app_url_verify.log 2>&1
      
      cat /tmp/app_url_verify.log
      cp /tmp/app_url_verify.log /var/app/current/storage/logs/eb_fixes/app_url_verify.log 2>/dev/null || true
