# Configurar variables de entorno de EB (mejor que editar .env)
# Estas variables se setean automáticamente como ENV en la instancia
# PHP puede leerlas directamente sin necesidad de .env

option_settings:
  aws:elasticbeanstalk:application:environment:
    # Laravel básico
    APP_NAME: "SIGO"
    APP_ENV: "production"
    APP_DEBUG: "false"
    APP_LOG_LEVEL: "error"
    
    # Base de datos - SQL Server
    DB_CONNECTION: "sqlsrv"
    DB_HOST: "bdsigoprod.ca7cms0eernu.us-east-1.rds.amazonaws.com"
    DB_PORT: "1433"
    DB_DATABASE: "BD_SIGO"
    DB_USERNAME: "admin"
    DB_PASSWORD: "vv8StWVd9Rx8JVc?"
    
    # SQL Server specific
    DB_ENCRYPT: "yes"
    DB_TRUST_SERVER_CERTIFICATE: "true"
    DB_LOGIN_TIMEOUT: "30"
    
    # Session
    SESSION_DRIVER: "file"
    SESSION_LIFETIME: "120"
    SESSION_ENCRYPT: "true"
    
    # Node/Frontend
    NODE_ENV: "production"

commands:
  01_verify_env_variables:
    command: |
      echo "=== Verificación de Variables de Entorno EB ===" > /tmp/eb_env_verify.log
      
      # Mostrar variables de entorno de EB
      echo "Variables EB configuradas:" >> /tmp/eb_env_verify.log
      env | grep -E "DB_|SESSION_|APP_|NODE_" | sort >> /tmp/eb_env_verify.log 2>&1 || echo "Ninguna variable encontrada" >> /tmp/eb_env_verify.log
      
      # Verificar que PHP puede leer las variables
      php -r "
      echo 'Variables disponibles para PHP:' . PHP_EOL;
      echo 'DB_HOST: ' . getenv('DB_HOST') . PHP_EOL;
      echo 'DB_USERNAME: ' . getenv('DB_USERNAME') . PHP_EOL;
      echo 'DB_TRUST_SERVER_CERTIFICATE: ' . getenv('DB_TRUST_SERVER_CERTIFICATE') . PHP_EOL;
      " >> /tmp/eb_env_verify.log 2>&1
      
      cat /tmp/eb_env_verify.log
      cp /tmp/eb_env_verify.log /var/app/current/storage/logs/eb_fixes/ 2>/dev/null || true

  02_create_env_if_missing:
    command: |
      echo "=== Verificación/Creación de .env ===" > /tmp/env_creation.log
      
      ENV_FILE="/var/app/current/.env"
      
      if [ -f "$ENV_FILE" ]; then
        echo "✓ .env ya existe" | tee -a /tmp/env_creation.log
      else
        echo "⚠ .env no existe, creando..." | tee -a /tmp/env_creation.log
        
        # Crear .env mínimo que lea variables de EB
        cat > "$ENV_FILE" << 'EOF'
# SIGO Configuration
# Nota: Las variables principales vienen de .ebextensions option_settings
# Esto es un respaldo para desarrollo local

APP_NAME=SIGO
APP_ENV=production
APP_DEBUG=false
APP_URL=https://sigo-app-env.eba-pjwh8vad.us-east-1.elasticbeanstalk.com

DB_CONNECTION=sqlsrv
DB_HOST=bdsigoprod.ca7cms0eernu.us-east-1.rds.amazonaws.com
DB_PORT=1433
DB_DATABASE=BD_SIGO

SESSION_DRIVER=file
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
CACHE_DRIVER=file
EOF
        
        echo "✓ .env creado" | tee -a /tmp/env_creation.log
      fi
      
      cp /tmp/env_creation.log /var/app/current/storage/logs/eb_fixes/ 2>/dev/null || true

  03_verify_laravel_bootstrap:
    command: |
      echo "=== Verificación de Bootstrap de Laravel ===" > /tmp/laravel_bootstrap.log
      
      cd /var/app/current
      
      # Verificar que bootstrap/app.php existe
      if [ -f "bootstrap/app.php" ]; then
        echo "✓ bootstrap/app.php existe" | tee -a /tmp/laravel_bootstrap.log
      else
        echo "❌ bootstrap/app.php no encontrado" | tee -a /tmp/laravel_bootstrap.log
        exit 1
      fi
      
      # Verificar que Laravel puede leer configuración
      php -r "
      try {
          \$app = require 'bootstrap/app.php';
          \$config = \$app->make('config');
          echo 'DB Connection: ' . \$config->get('database.default') . PHP_EOL;
          echo 'DB Host: ' . \$config->get('database.connections.sqlsrv.host') . PHP_EOL;
          echo '✓ Bootstrap de Laravel funciona correctamente' . PHP_EOL;
      } catch (Exception \$e) {
          echo '❌ Error en bootstrap: ' . \$e->getMessage() . PHP_EOL;
          exit(1);
      }
      " >> /tmp/laravel_bootstrap.log 2>&1
      
      cat /tmp/laravel_bootstrap.log
      cp /tmp/laravel_bootstrap.log /var/app/current/storage/logs/eb_fixes/ 2>/dev/null || true

container_commands:
  01_artisan_cache:
    command: |
      cd /var/app/current
      php artisan config:clear 2>&1
      php artisan config:cache 2>&1
      php artisan cache:clear 2>&1
    leader_only: true

  02_artisan_migrate:
    command: |
      cd /var/app/current
      # Solo ejecutar migraciones si la BD está disponible
      php artisan migrate --force 2>&1 | tee /tmp/migrate.log || echo "⚠ Migraciones opcional en este punto"
    leader_only: true
    ignore_errors: true
