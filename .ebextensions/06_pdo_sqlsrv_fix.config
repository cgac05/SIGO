# Fix: pdo_sqlsrv.so not loaded - Copy missing extension
# Problema: sqlsrv.so está cargado pero pdo_sqlsrv.so falta
commands:
  01_find_pdo_sqlsrv:
    command: |
      echo "=== Searching for pdo_sqlsrv.so ===" | tee /tmp/pdo_fix.log
      
      # Buscar en múltiples ubicaciones
      echo "Searching in standard locations..." | tee -a /tmp/pdo_fix.log
      find /usr -name "pdo_sqlsrv.so" 2>/dev/null | tee -a /tmp/pdo_fix.log || echo "Not found in /usr" | tee -a /tmp/pdo_fix.log
      
      # Buscar en cualquier lugar
      echo "Searching in entire filesystem (limiting to common paths)..." | tee -a /tmp/pdo_fix.log
      find /opt /home /var -name "pdo_sqlsrv.so" 2>/dev/null | tee -a /tmp/pdo_fix.log || echo "Not found" | tee -a /tmp/pdo_fix.log
      
      # Buscar archivos .so relacionados
      echo "Looking for related .so files..." | tee -a /tmp/pdo_fix.log
      find /usr/lib64/php/modules -name "*sqlsrv*" 2>/dev/null | tee -a /tmp/pdo_fix.log

  02_check_pecl_cache:
    command: |
      echo "=== Checking PECL cache ===" | tee -a /tmp/pdo_fix.log
      
      # PECL a menudo descarga pero no instala correctamente
      PECL_CACHE="/usr/src/pecl"
      if [ -d "$PECL_CACHE" ]; then
        echo "PECL cache found:" | tee -a /tmp/pdo_fix.log
        find "$PECL_CACHE" -name "pdo_sqlsrv*" 2>/dev/null | tee -a /tmp/pdo_fix.log
        
        # Buscar .so compilado en la carpeta de trabajo
        find "$PECL_CACHE" -name "*.so" 2>/dev/null | grep -i sqlsrv | tee -a /tmp/pdo_fix.log
      fi

  03_reinstall_pdo_sqlsrv:
    command: |
      echo "=== Reinstalling pdo_sqlsrv ===" | tee -a /tmp/pdo_fix.log
      
      EXT_DIR="/usr/lib64/php/modules"
      echo "Extension directory: $EXT_DIR" | tee -a /tmp/pdo_fix.log
      
      # Método 1: Intentar con dnf (el más simple)
      echo "Attempting dnf reinstall..." | tee -a /tmp/pdo_fix.log
      dnf reinstall -y php-pdo_sqlsrv 2>&1 | tee -a /tmp/pdo_fix.log
      
      # Verificar si se copió
      if [ -f "$EXT_DIR/pdo_sqlsrv.so" ]; then
        echo "✓ pdo_sqlsrv.so found after dnf reinstall" | tee -a /tmp/pdo_fix.log
        ls -lah "$EXT_DIR/pdo_sqlsrv.so" | tee -a /tmp/pdo_fix.log
      else
        echo "⚠ dnf reinstall didn't install file, trying PECL..." | tee -a /tmp/pdo_fix.log
        
        # Método 2: Recompile with PECL if not found
        printf "\n" | pecl install --force pdo_sqlsrv 2>&1 | tee -a /tmp/pdo_fix.log
        
        # Verificar resultado
        if [ -f "$EXT_DIR/pdo_sqlsrv.so" ]; then
          echo "✓ pdo_sqlsrv.so installed via PECL" | tee -a /tmp/pdo_fix.log
          ls -lah "$EXT_DIR/pdo_sqlsrv.so" | tee -a /tmp/pdo_fix.log
        else
          echo "✗ PECL also failed, checking for compiled .so files..." | tee -a /tmp/pdo_fix.log
          find / -name "pdo_sqlsrv.so" 2>/dev/null | head -5 | tee -a /tmp/pdo_fix.log
        fi
      fi

  04_verify_ini_files:
    command: |
      echo "=== Verifying INI files ===" | tee -a /tmp/pdo_fix.log
      
      # Verificar que los archivos .ini están correctamente configurados
      echo "Content of /etc/php.d/30-sqlsrv.ini:" | tee -a /tmp/pdo_fix.log
      cat /etc/php.d/30-sqlsrv.ini | tee -a /tmp/pdo_fix.log
      
      echo "" | tee -a /tmp/pdo_fix.log
      echo "Content of /etc/php.d/30-pdo_sqlsrv.ini:" | tee -a /tmp/pdo_fix.log
      cat /etc/php.d/30-pdo_sqlsrv.ini | tee -a /tmp/pdo_fix.log
      
      # Asegurar que los permisos están correctos
      chmod 644 /etc/php.d/30-sqlsrv.ini /etc/php.d/30-pdo_sqlsrv.ini

  05_clear_php_cache:
    command: |
      echo "=== Clearing PHP cache ===" | tee -a /tmp/pdo_fix.log
      
      # Limpiar opcache si existe
      php -r "opcache_reset();" 2>/dev/null || echo "OPcache not available" | tee -a /tmp/pdo_fix.log
      
      # Crear archivo que fuerza recarga
      touch /tmp/php_reload_required

  06_restart_php_fpm:
    command: |
      echo "=== Restarting PHP-FPM ===" | tee -a /tmp/pdo_fix.log
      
      # Dar tiempo antes de reiniciar
      sleep 2
      
      if systemctl restart php-fpm 2>&1 | tee -a /tmp/pdo_fix.log; then
        echo "✓ PHP-FPM restarted successfully" | tee -a /tmp/pdo_fix.log
        sleep 2
      else
        echo "⚠ Trying alternative restart method..." | tee -a /tmp/pdo_fix.log
        service php-fpm restart 2>&1 | tee -a /tmp/pdo_fix.log
      fi

  07_verify_pdo_sqlsrv_loaded:
    command: |
      echo "=== Final Verification ===" | tee -a /tmp/pdo_fix.log
      
      echo "Checking if pdo_sqlsrv is now loaded..." | tee -a /tmp/pdo_fix.log
      php -m | grep -i pdo_sqlsrv | tee -a /tmp/pdo_fix.log
      
      if php -m | grep -q -i pdo_sqlsrv; then
        echo "✓ SUCCESS: pdo_sqlsrv is now loaded!" | tee -a /tmp/pdo_fix.log
      else
        echo "✗ FAILED: pdo_sqlsrv is still not loaded" | tee -a /tmp/pdo_fix.log
        echo "Debugging info:" | tee -a /tmp/pdo_fix.log
        php -i | grep -i pdo_sqlsrv | head -10 | tee -a /tmp/pdo_fix.log
        php -i | grep -i "extension_dir" | tee -a /tmp/pdo_fix.log
      fi
      
      echo "" | tee -a /tmp/pdo_fix.log
      echo "Available PDO drivers:" | tee -a /tmp/pdo_fix.log
      php -r "print_r(PDO::getAvailableDrivers());" 2>&1 | tee -a /tmp/pdo_fix.log

  08_copy_logs_to_storage:
    command: |
      # Copiar logs a carpeta persistente
      mkdir -p /var/app/current/storage/logs/eb_fixes
      cp /tmp/pdo_fix.log /var/app/current/storage/logs/eb_fixes/pdo_sqlsrv_fix_$(date +%Y%m%d_%H%M%S).log 2>/dev/null || true
      
      # Mostrar dónde se guardó
      echo "Fix logs saved to /var/app/current/storage/logs/eb_fixes/" | tee -a /tmp/pdo_fix.log

container_commands:
  01_final_db_test:
    command: |
      cd /var/app/current
      
      echo "=== Testing Database Connection ===" >> /var/app/current/storage/logs/eb_fixes/final_test.log
      
      # Script PHP de prueba
      php << 'TESTEOF'
      <?php
      echo "=== PDO Driver Test ===\n";
      echo "Available PDO drivers: " . implode(", ", PDO::getAvailableDrivers()) . "\n";
      
      if (in_array('sqlsrv', PDO::getAvailableDrivers())) {
          echo "✓ sqlsrv driver is available\n";
          
          // Intentar conexión
          try {
              $host = getenv('DB_HOST');
              $db = getenv('DB_DATABASE');
              $user = getenv('DB_USERNAME');
              $pass = getenv('DB_PASSWORD');
              
              if ($host && $user) {
                  $dsn = "sqlsrv:Server=$host,1433;Database=$db";
                  $pdo = new PDO($dsn, $user, $pass);
                  echo "✓ Database connection successful!\n";
              } else {
                  echo "⚠ Credentials not configured\n";
              }
          } catch (Exception $e) {
              echo "✗ Connection error: " . $e->getMessage() . "\n";
          }
      } else {
          echo "✗ sqlsrv driver is NOT available\n";
          echo "Loaded extensions:\n";
          foreach (get_loaded_extensions() as $ext) {
              if (strpos($ext, 'sqlsrv') !== false || strpos($ext, 'pdo') !== false) {
                  echo "  - $ext\n";
              }
          }
      }
      TESTEOF
    leader_only: true
    ignoreErrors: true
