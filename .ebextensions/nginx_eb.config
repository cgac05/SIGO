files:
  /etc/nginx/conf.d/laravel.conf:
    mode: "000644"
    owner: root
    group: root
    content: |
      # Laravel-specific configuration for Elastic Beanstalk
      
      # Main server block customization
      client_max_body_size 10M;
      client_body_timeout 60s;
      
      # PHP FPM upstream
      upstream php_fpm {
        server 127.0.0.1:9000;
        keepalive 10;
      }

container_commands:
  01_stop_nginx:
    command: "sudo service nginx stop || sudo systemctl stop nginx || true"
    ignoreErrors: true
  02_create_laravel_conf:
    command: |
      cat > /etc/nginx/conf.d/01_laravel_root.conf << 'EOF'
      root /var/www/html/public;
      index index.php index.html index.htm;
      
      # Security
      server_tokens off;
      
      # Deny hidden files
      location ~ /\. {
        deny all;
        access_log off;
        log_not_found off;
      }
      
      # Deny app directories
      location ~ ^/(app|bootstrap|config|database|resources|storage|tests|vendor)/ {
        deny all;
        access_log off;
        log_not_found off;
      }
      
      # Static files caching
      location ~* \.(jpg|jpeg|png|gif|ico|css|js|svg|woff|woff2|ttf|eot|pdf)$ {
        expires 30d;
        add_header Cache-Control "public, immutable";
        access_log off;
      }
      
      # Laravel routing
      location / {
        try_files $uri $uri/ /index.php$is_args$args;
      }
      
      # PHP handler
      location ~ \.php$ {
        fastcgi_pass 127.0.0.1:9000;
        fastcgi_index index.php;
        fastcgi_param SCRIPT_FILENAME $realpath_root$fastcgi_script_name;
        fastcgi_param DOCUMENT_ROOT $realpath_root;
        include fastcgi_params;
      }
      EOF
    leader_only: true
  03_reload_nginx:
    command: "sudo service nginx restart || sudo systemctl restart nginx || true"
    leader_only: true
