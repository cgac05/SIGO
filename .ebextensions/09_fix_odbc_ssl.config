# Configurar ODBC Driver para aceptar certificados de RDS
# El problema: ODBC Driver 18 por defecto verifica certificados SSL
# Solución: Confiar en certificados autofirmados de RDS

files:
  "/etc/odbcinst.ini":
    mode: "000644"
    owner: root
    group: root
    content: |
      [ODBC Driver 18 for SQL Server]
      Description=Microsoft ODBC Driver 18 for SQL Server
      Driver=libodbcsqlsrv.so.18.3
      UsageCount=1
      # Aceptar certificados SSL autofirmados de RDS
      TrustServerCertificate=yes

  "/etc/odbc.ini":
    mode: "000644"
    owner: root
    group: root
    content: |
      [SIGO-RDS]
      Driver=ODBC Driver 18 for SQL Server
      Server=bdsigoprod.ca7cms0eernu.us-east-1.rds.amazonaws.com,1433
      Database=BD_SIGO
      TrustServerCertificate=yes
      Encrypt=yes
      Connection Timeout=30

commands:
  01_verify_odbc_driver:
    command: |
      echo "=== Verificación de ODBC Driver ===" > /tmp/odbc_verify.log
      
      # Verificar que ODBC Driver 18 está instalado
      if odbcinst -d -l | grep -i "ODBC Driver 18"; then
        echo "✓ ODBC Driver 18 instalado" | tee -a /tmp/odbc_verify.log
      else
        echo "❌ ODBC Driver 18 no encontrado" | tee -a /tmp/odbc_verify.log
        exit 1
      fi
      
      # Verificar archivos del driver
      echo "Archivos del driver:" >> /tmp/odbc_verify.log
      find /usr -name "*odbcsqlsrv*" 2>/dev/null >> /tmp/odbc_verify.log
      
      # Verificar configuración ODBC
      echo "Configuración ODBC:" >> /tmp/odbc_verify.log
      cat /etc/odbcinst.ini >> /tmp/odbc_verify.log 2>&1
      cat /etc/odbc.ini >> /tmp/odbc_verify.log 2>&1

  02_test_odbc_connection:
    command: |
      echo "=== Test de Conexión ODBC ===" > /tmp/odbc_test.log
      
      # Intentar conectar con isql (herramienta de prueba ODBC)
      if command -v isql &> /dev/null; then
        echo "Intentando conexión ODBC a RDS..." | tee -a /tmp/odbc_test.log
        
        # No queremos exponer la contraseña en logs, así que solo indicamos intent
        isql -v SIGO-RDS admin "vv8StWVd9Rx8JVc?" -b << EOF >> /tmp/odbc_test.log 2>&1
        SELECT 1
        GO
        quit
EOF
      else
        echo "⚠ isql no disponible, saltando test ODBC" | tee -a /tmp/odbc_test.log
      fi

  03_configure_php_odbc:
    command: |
      echo "=== Configuración PHP ODBC ===" > /tmp/php_odbc.log
      
      # Verificar que pdo_odbc está compilado
      php -m | grep -i odbc >> /tmp/php_odbc.log 2>&1
      
      # Configurar environment variable para ignorar SSL si es necesario
      echo "Configurando variables de entorno..." >> /tmp/php_odbc.log
      
      # Agregar a /etc/php-fpm.d/www.conf si no existe
      if ! grep -q "SQLSERVERCERT" /etc/php-fpm.d/www.conf; then
        cat >> /etc/php-fpm.d/www.conf << 'EOF'

; SQL Server SSL settings
env[SQLSERVERCERT]=ignore
EOF
      fi
      
      echo "✓ PHP ODBC configurado" >> /tmp/php_odbc.log

  04_restart_odbc_services:
    command: |
      echo "=== Reiniciando servicios ODBC ===" > /tmp/odbc_restart.log
      
      # PHP-FPM ya debería tener la configuración cargada
      if systemctl restart php-fpm 2>&1 | tee -a /tmp/odbc_restart.log; then
        echo "✓ PHP-FPM reiniciado" | tee -a /tmp/odbc_restart.log
      else
        echo "⚠ PHP-FPM restart con systemctl falló, intentando service" | tee -a /tmp/odbc_restart.log
        service php-fpm restart 2>&1 | tee -a /tmp/odbc_restart.log || true
      fi

  05_test_laravel_connection:
    command: |
      cd /var/app/current
      
      echo "=== Test de Conexión Laravel ===" > /tmp/laravel_connection.log
      
      # Crear un script temporal para probar conexión
      cat > /tmp/test_db_connection.php << 'EOF'
<?php
require '/var/app/current/bootstrap/autoload.php';
require '/var/app/current/bootstrap/app.php';

try {
    DB::connection('sqlsrv')->select('SELECT 1');
    echo "✓ Conexión exitosa a SQL Server";
} catch (Exception $e) {
    echo "❌ Error: " . $e->getMessage();
    exit(1);
}
EOF
      
      php /tmp/test_db_connection.php >> /tmp/laravel_connection.log 2>&1
      
      # Copiar logs
      cp /tmp/odbc_verify.log /var/app/current/storage/logs/eb_fixes/ 2>/dev/null || true
      cp /tmp/odbc_test.log /var/app/current/storage/logs/eb_fixes/ 2>/dev/null || true
      cp /tmp/php_odbc.log /var/app/current/storage/logs/eb_fixes/ 2>/dev/null || true
      cp /tmp/odbc_restart.log /var/app/current/storage/logs/eb_fixes/ 2>/dev/null || true
      cp /tmp/laravel_connection.log /var/app/current/storage/logs/eb_fixes/ 2>/dev/null || true
