# Fix agresivo para SSL certificate error en RDS
# Problema: ODBC Driver 18 rechaza certificados autofirmados de RDS
# Solución: Configurar ODBC para no validar certificados (seguro en VPC privada)

files:
  # Crear directorio de logs si no existe
  "/var/app/current/storage/logs/eb_fixes/.gitkeep":
    mode: "000644"
    owner: webapp
    group: webapp
    content: ""

  "/etc/odbcinst.ini":
    mode: "000644"
    owner: root
    group: root
    content: |
      [ODBC Driver 18 for SQL Server]
      Description=Microsoft ODBC Driver 18 for SQL Server
      Driver=libodbcsqlsrv.so.18.3
      UsageCount=1

  "/etc/odbc.ini":
    mode: "000644"
    owner: root
    group: root
    content: |
      [SIGO-RDS]
      Driver=ODBC Driver 18 for SQL Server
      Server=bdsigoprod.ca7cms0eernu.us-east-1.rds.amazonaws.com,1433
      Database=BD_SIGO
      # IMPORTANTE: Deshabilitar validación de certificados
      # Esto es seguro porque estamos en AWS VPC (conexión privada)
      TrustServerCertificate=yes
      Encrypt=yes
      Connection Timeout=30

commands:
  01_ensure_log_directory:
    command: |
      echo "=== Creando directorio de logs ===" > /tmp/logs_setup.log
      
      LOG_DIR="/var/app/current/storage/logs/eb_fixes"
      mkdir -p "$LOG_DIR" 2>&1 | tee -a /tmp/logs_setup.log
      
      # Dar permisos correctos
      chmod 755 "$LOG_DIR" 2>&1 | tee -a /tmp/logs_setup.log
      chown -R webapp:webapp "$LOG_DIR" 2>&1 | tee -a /tmp/logs_setup.log
      
      if [ -d "$LOG_DIR" ]; then
        echo "✓ Directorio creado: $LOG_DIR" | tee -a /tmp/logs_setup.log
      else
        echo "❌ Error creando directorio" | tee -a /tmp/logs_setup.log
      fi
      
      cp /tmp/logs_setup.log "$LOG_DIR/" 2>/dev/null || true

  02_check_odbc_driver_files:
    command: |
      echo "=== Verificación de archivos ODBC ===" > /tmp/odbc_files.log
      
      echo "Buscando libodbcsqlsrv.so..." | tee -a /tmp/odbc_files.log
      find /usr -name "libodbcsqlsrv*" -type f 2>/dev/null | tee -a /tmp/odbc_files.log
      
      echo "Buscando msodbcsql..." | tee -a /tmp/odbc_files.log
      find /opt -name "msodbcsql*" -type d 2>/dev/null | tee -a /tmp/odbc_files.log
      
      echo "Directorio /opt/msodbcsql18:" | tee -a /tmp/odbc_files.log
      ls -la /opt/msodbcsql18/ 2>&1 | tee -a /tmp/odbc_files.log || echo "No existe" | tee -a /tmp/odbc_files.log
      
      cp /tmp/odbc_files.log /var/app/current/storage/logs/eb_fixes/ 2>/dev/null || true

  03_fix_odbcinst_driver_path:
    command: |
      echo "=== Fix rutas de ODBC Driver ===" > /tmp/odbc_driver_fix.log
      
      # Encontrar la ruta exacta de libodbcsqlsrv.so
      DRIVER_PATH=$(find /usr -name "libodbcsqlsrv.so*" -type f 2>/dev/null | head -1)
      
      if [ -z "$DRIVER_PATH" ]; then
        echo "⚠ libodbcsqlsrv.so no encontrado en /usr, buscando en /opt..." | tee -a /tmp/odbc_driver_fix.log
        DRIVER_PATH=$(find /opt -name "libodbcsqlsrv.so*" -type f 2>/dev/null | head -1)
      fi
      
      if [ -n "$DRIVER_PATH" ]; then
        echo "✓ Driver encontrado en: $DRIVER_PATH" | tee -a /tmp/odbc_driver_fix.log
        
        # Actualizar odbcinst.ini con la ruta correcta
        sed -i "s|Driver=libodbcsqlsrv.so.*|Driver=$DRIVER_PATH|g" /etc/odbcinst.ini
        
        echo "Contenido actualizado de /etc/odbcinst.ini:" | tee -a /tmp/odbc_driver_fix.log
        cat /etc/odbcinst.ini | tee -a /tmp/odbc_driver_fix.log
      else
        echo "❌ Driver ODBC no encontrado en el sistema" | tee -a /tmp/odbc_driver_fix.log
      fi
      
      cp /tmp/odbc_driver_fix.log /var/app/current/storage/logs/eb_fixes/ 2>/dev/null || true

  04_test_odbc_connection:
    command: |
      echo "=== Test de Conexión ODBC ===" > /tmp/odbc_connection_test.log
      
      # Test con isql
      if command -v isql &> /dev/null; then
        echo "Intentando conexión con isql..." | tee -a /tmp/odbc_connection_test.log
        
        # Usar timeout para evitar cuelges
        timeout 10 isql -v SIGO-RDS admin "vv8StWVd9Rx8JVc?" -b << EOF 2>&1 | tee -a /tmp/odbc_connection_test.log
        SELECT 1 AS test
        GO
        quit
EOF
        
        if [ $? -eq 0 ]; then
          echo "✓ Conexión ODBC exitosa" | tee -a /tmp/odbc_connection_test.log
        else
          echo "⚠ Conexión ODBC falló o timeout" | tee -a /tmp/odbc_connection_test.log
        fi
      else
        echo "⚠ isql no disponible, saltando test ODBC" | tee -a /tmp/odbc_connection_test.log
      fi
      
      cp /tmp/odbc_connection_test.log /var/app/current/storage/logs/eb_fixes/ 2>/dev/null || true

  05_configure_pdo_attributes:
    command: |
      echo "=== Configuración de PDO attributes ===" > /tmp/pdo_config.log
      
      # Crear archivo que Laravel puede incluir para configurar PDO correctamente
      cat > /var/app/current/config/pdo_attributes.php << 'EOF'
<?php

// PDO SQL Server configuration attributes
// Esto se debe cargar en bootstrap/app.php o service provider

return [
    'attributes' => [
        // Importante para SQL Server: deshabilitar emulación de prepare
        \PDO::ATTR_EMULATE_PREPARES => false,
        
        // Error mode
        \PDO::ATTR_ERRMODE => \PDO::ERRMODE_EXCEPTION,
        
        // Timeout de conexión
        \PDO::ATTR_TIMEOUT => 30,
    ],
    
    // Options para la cadena de conexión SQL Server
    'connection_options' => [
        'TrustServerCertificate' => 'yes',  // Aceptar certificados autofirmados
        'Encrypt' => 'yes',
        'Connection Timeout' => 30,
    ],
];
EOF
      
      echo "✓ Archivo pdo_attributes.php creado" | tee -a /tmp/pdo_config.log
      cp /tmp/pdo_config.log /var/app/current/storage/logs/eb_fixes/ 2>/dev/null || true

  06_update_database_config:
    command: |
      echo "=== Actualización de configuración de BD ===" > /tmp/db_config_update.log
      
      # Crear un script que agregue opciones de conexión a config/database.php
      cat > /tmp/update_db_config.php << 'PHPEOF'
<?php
$configFile = '/var/app/current/config/database.php';
$content = file_get_contents($configFile);

// Buscar la sección de sqlsrv y agregar opciones de conexión
$needsUpdate = strpos($content, "'trust_server_certificate'") === false;

if ($needsUpdate) {
    echo "Actualizando configuración SQL Server...\n";
    
    // Reemplazar la línea del login_timeout con opciones completas
    $pattern = "/'login_timeout' => env\('DB_LOGIN_TIMEOUT', 30\),/";
    $replacement = <<<'REPLACEMENT'
'login_timeout' => env('DB_LOGIN_TIMEOUT', 30),
            
            // SSL/Certificate options
            'trust_server_certificate' => env('DB_TRUST_SERVER_CERTIFICATE', 'true') === 'true',
            'encrypt' => env('DB_ENCRYPT', 'yes') === 'yes',
REPLACEMENT;
    
    $content = preg_replace($pattern, $replacement, $content);
    file_put_contents($configFile, $content);
    
    echo "✓ Configuración actualizada\n";
} else {
    echo "✓ Configuración ya tiene opciones SSL\n";
}
PHPEOF

      php /tmp/update_db_config.php 2>&1 | tee -a /tmp/db_config_update.log
      cp /tmp/db_config_update.log /var/app/current/storage/logs/eb_fixes/ 2>/dev/null || true

  07_restart_php_fpm:
    command: |
      echo "=== Reinicio de PHP-FPM ===" > /tmp/php_fpm_restart.log
      
      if systemctl restart php-fpm 2>&1 | tee -a /tmp/php_fpm_restart.log; then
        echo "✓ PHP-FPM reiniciado correctamente" | tee -a /tmp/php_fpm_restart.log
      else
        echo "⚠ Restart con systemctl falló, intentando service..." | tee -a /tmp/php_fpm_restart.log
        service php-fpm restart 2>&1 | tee -a /tmp/php_fpm_restart.log || echo "❌ Ambos métodos fallaron" | tee -a /tmp/php_fpm_restart.log
      fi
      
      cp /tmp/php_fpm_restart.log /var/app/current/storage/logs/eb_fixes/ 2>/dev/null || true

  08_test_laravel_connection:
    command: |
      cd /var/app/current
      
      echo "=== Test de Conexión Laravel ===" > /tmp/laravel_db_test.log
      
      # Test simple de conexión
      php artisan tinker --execute="
      try {
          \$result = DB::select('SELECT 1 as test');
          echo '✓ Conexión SQL Server EXITOSA' . PHP_EOL;
          var_dump(\$result);
      } catch (Exception \$e) {
          echo '❌ Error de conexión: ' . \$e->getMessage() . PHP_EOL;
          exit(1);
      }
      " 2>&1 | tee -a /tmp/laravel_db_test.log || echo "⚠ Test fallido o tinker no disponible" | tee -a /tmp/laravel_db_test.log
      
      cp /tmp/laravel_db_test.log /var/app/current/storage/logs/eb_fixes/ 2>/dev/null || true

  09_final_verification:
    command: |
      echo "=== Verificación Final ===" > /tmp/final_verification.log
      
      echo "Estado del deployment SSL:" | tee -a /tmp/final_verification.log
      echo "1. ODBC Driver:" | tee -a /tmp/final_verification.log
      odbcinst -q -l -d 2>&1 | tee -a /tmp/final_verification.log
      
      echo "2. Configuración ODBC:" | tee -a /tmp/final_verification.log
      cat /etc/odbc.ini | tee -a /tmp/final_verification.log
      
      echo "3. Variables de entorno DB:" | tee -a /tmp/final_verification.log
      env | grep DB_ | tee -a /tmp/final_verification.log
      
      cp /tmp/final_verification.log /var/app/current/storage/logs/eb_fixes/ 2>/dev/null || true

option_settings:
  aws:elasticbeanstalk:application:environment:
    # Forzar variables adicionales
    SQLSERVERCERT: "ignore"
    ODBCINSTINI: "/etc/odbcinst.ini"
    ODBCINI: "/etc/odbc.ini"
