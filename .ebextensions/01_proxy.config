files:
  /opt/elasticbeanstalk/tasks/bundlelogs.d/01_nginx.conf:
    content: |
      /var/log/nginx
  
  /etc/nginx/conf.d/gzip.conf:
    mode: "000644"
    owner: root
    group: root
    content: |
      gzip on;
      gzip_comp_level 4;
      gzip_types text/plain text/css text/xml text/javascript 
                 application/x-javascript application/xml+rss 
                 application/json application/javascript;

  /etc/nginx/conf.d/laravel_routes.conf:
    mode: "000644"
    owner: root
    group: root
    content: |
      # Laravel URL rewriting configuration
      # This file ensures all non-file, non-directory requests are routed to index.php
      
      location / {
        # Check if file exists, if not go to index.php
        if (!-e $request_filename) {
          rewrite ^(.*)$ /index.php?$query_string last;
        }
      }

container_commands:
  01_write_nginx_conf:
    command: |
      cat > /etc/nginx/conf.d/01_laravel.conf << 'NGINXEOF'
      client_max_body_size 20M;
      
      server {
        listen 80 default_server;
        listen [::]:80 default_server;
        
        server_name _;
        root /var/www/html/public;
        index index.php index.html index.htm;
        
        # Logging
        access_log /var/log/nginx/access.log;
        error_log /var/log/nginx/error.log warn;
        
        # Security
        server_tokens off;
        
        # Don't serve hidden files
        location ~ /\. {
          deny all;
        }
        
        # Serve static files without routing to PHP
        location ~* ^/(?:css|js|images|media|archive|robots\.txt)/ {
          expires max;
          add_header Pragma "public";
          add_header Cache-Control "public, immutable";
        }
        
        # Laravel routing - route everything through index.php
        location / {
          try_files $uri $uri/ /index.php$is_args$args;
        }
        
        # Pass PHP files to fpm
        location ~ \.php$ {
          # Prevent accessing files outside /var/www/html/public
          try_files $uri =404;
          fastcgi_pass 127.0.0.1:9000;
          fastcgi_index index.php;
          fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
          fastcgi_param DOCUMENT_ROOT $document_root;
          include fastcgi_params;
          
          # Pass headers
          fastcgi_param HTTP_AUTHORIZATION $http_authorization if_not_empty;
          
          # Timeouts
          fastcgi_connect_timeout 60;
          fastcgi_send_timeout 300;
          fastcgi_read_timeout 300;
        }
      }
      NGINXEOF
    leader_only: true
  02_test_nginx:
    command: "nginx -t"
    ignoreErrors: true
  03_reload_nginx:
    command: "service nginx reload"
    ignoreErrors: true
