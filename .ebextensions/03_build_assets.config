commands:
  00_install_dependencies:
    command: |
      cd /var/app/current
      echo "📦 Instalando dependencias npm..."
      npm install 2>&1 | tee /tmp/npm_install.log
      if [ $? -ne 0 ]; then
        echo "⚠️ npm install falló, intentando con npm ci"
        npm ci 2>&1 | tee -a /tmp/npm_install.log
      fi
  01_build_assets:
    command: |
      cd /var/app/current
      echo "🔨 Compilando assets con Vite..."
      echo "Node version: $(node --version)"
      echo "NPM version: $(npm --version)"
      npm run build 2>&1 | tee /tmp/npm_build.log
      BUILD_STATUS=$?
      echo "Build exit code: $BUILD_STATUS"
      if [ $BUILD_STATUS -ne 0 ]; then
        echo "⚠️ Build falló - revisar /tmp/npm_build.log"
      else
        echo "✅ Build exitoso"
      fi
  02_verify_assets:
    command: |
      echo "🔍 Verificando assets compilados..."
      if [ -f /var/app/current/public/build/manifest.json ]; then
        echo "✅ manifest.json existe"
        cat /var/app/current/public/build/manifest.json | head -5
      else
        echo "❌ CRÍTICO: manifest.json NO ENCONTRADO"
        ls -la /var/app/current/public/build/ 2>&1 || echo "build dir no existe"
        cat /tmp/npm_build.log
      fi
      if [ -d /var/app/current/public/build/assets ]; then
        echo "✅ Directorio assets existe"
        ls -la /var/app/current/public/build/assets/ | head -5
      else
        echo "❌ Directorio assets NO ENCONTRADO"
      fi
  03_laravel_commands:
    command: |
      cd /var/app/current
      php artisan cache:clear || true
      php artisan config:cache || true
      php artisan view:clear || true
      echo "✓ Cache limpiado"

container_commands:
  01_set_permissions:
    command: |
      chown -R webapp:webapp /var/app/current/storage /var/app/current/bootstrap/cache 2>/dev/null || true
      chmod -R 755 /var/app/current/storage /var/app/current/bootstrap/cache 2>/dev/null || true

