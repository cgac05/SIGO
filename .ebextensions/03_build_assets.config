commands:
  00_install_dependencies:
    command: |
      cd /var/app/current
      npm ci --omit=dev || npm install --omit=dev || true
  01_build_assets:
    command: |
      cd /var/app/current
      echo "🔨 Compilando assets..."
      npm install terser --save-dev 2>/dev/null || true
      npm run build || true
      echo "✓ Build completado (continúa incluso si falla)"
  02_verify_assets:
    command: |
      if [ -d /var/app/current/public/build ]; then
        echo "✓ Directorio build existe"
        ls -la /var/app/current/public/build/ | head -10
      else
        echo "⚠ Directorio build no encontrado - usando assets previos"
      fi
  03_laravel_commands:
    command: |
      cd /var/app/current
      php artisan cache:clear || true
      php artisan config:cache || true
      php artisan view:clear || true
      echo "✓ Cache limpiado"

container_commands:
  01_set_permissions:
    command: |
      chown -R webapp:webapp /var/app/current/storage /var/app/current/bootstrap/cache 2>/dev/null || true
      chmod -R 755 /var/app/current/storage /var/app/current/bootstrap/cache 2>/dev/null || true

