commands:
  00_install_dependencies:
    command: |
      cd /var/app/current
      npm ci --omit=dev --legacy-peer-deps || npm install --omit=dev
  01_build_assets:
    command: |
      cd /var/app/current
      npm run build 2>&1 | tee /tmp/npm_build.log
      if [ ${PIPESTATUS[0]} -ne 0 ]; then
        echo "❌ Error en npm run build"
        cat /tmp/npm_build.log
        # Continuar de todas formas si ya existen assets compilados
        if [ ! -f /var/app/current/public/build/manifest.json ]; then
          exit 1
        fi
      else
        echo "✓ Assets compilados exitosamente"
      fi
  02_verify_assets:
    command: |
      if [ -f /var/app/current/public/build/manifest.json ]; then
        echo "✓ manifest.json existe"
        cat /var/app/current/public/build/manifest.json | head -20
      else
        echo "⚠ manifest.json NO encontrado"
      fi
  03_laravel_setup:
    command: |
      cd /var/app/current
      php artisan cache:clear 2>&1 | tee /tmp/cache_clear.log
      php artisan config:cache 2>&1 | tee -a /tmp/cache_clear.log
      php artisan view:cache 2>&1 | tee -a /tmp/cache_clear.log

container_commands:
  04_set_permissions:
    command: |
      chown -R webapp:webapp /var/app/current/storage /var/app/current/bootstrap/cache
      chmod -R 755 /var/app/current/storage /var/app/current/bootstrap/cache
