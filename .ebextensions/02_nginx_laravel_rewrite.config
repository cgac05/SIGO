commands:
  01_create_laravel_nginx_conf:
    command: |
      cat > /tmp/elasticbeanstalk.conf << 'EOFNGINX'
      location / {
          # Rewrite all requests to non-existent files/directories to index.php
          if (!-e $request_filename) {
              rewrite ^(.*)$ /index.php/$1 last;
          }
      }
      
      location ~ ^(.+\.php)(.*)$ {
          fastcgi_split_path_info ^(.+\.php)(.*)$;
          fastcgi_pass 127.0.0.1:9000;
          fastcgi_index index.php;
          fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
          include fastcgi_params;
      }
      EOFNGINX
      
      echo "✓ Laravel nginx config template created at /tmp/elasticbeanstalk.conf"

container_commands:
  01_install_laravel_nginx_config:
    command: |
      # Create the directory if it doesn't exist
      mkdir -p /etc/nginx/conf.d/elasticbeanstalk/
      
      # Copy our Laravel configuration
      if [ -f /tmp/elasticbeanstalk.conf ]; then
          cp /tmp/elasticbeanstalk.conf /etc/nginx/conf.d/elasticbeanstalk/01_laravel.conf
          echo "✓ Laravel nginx configuration installed"
      else
          echo "✗ Source file not found"
      fi
      
  02_test_nginx_config:
    command: |
      # Test the nginx configuration
      if nginx -t 2>&1 | grep -q "successful"; then
          echo "✓ Nginx configuration test passed"
          systemctl reload nginx 2>/dev/null || service nginx reload 2>/dev/null || true
          echo "✓ Nginx reloaded"
      else
          echo "✗ Nginx configuration test failed"
          nginx -t
          exit 1
      fi
