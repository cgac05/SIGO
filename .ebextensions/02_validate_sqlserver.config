# Validación de drivers SQL Server después del deploy
commands:
  01_check_php_modules:
    command: |
      echo "=== Verificando módulos PHP ===" 
      php -m | grep -i sqlsrv && echo "✓ sqlsrv instalado" || echo "✗ sqlsrv NO instalado"
      php -m | grep -i pdo_sqlsrv && echo "✓ pdo_sqlsrv instalado" || echo "✗ pdo_sqlsrv NO instalado"
  02_check_php_ini:
    command: |
      echo "=== Verificando php.ini ===" 
      grep -r "extension.*sqlsrv" /etc/php.d/ || echo "Extensiones no configuradas en php.d"
  03_check_laravel_config:
    command: |
      echo "=== Verificando conexión a BD ===" 
      cd /var/app/current && php artisan config:cache && echo "✓ Config cache OK"

container_commands:
  01_test_db_connection:
    command: |
      cd /var/app/current && php artisan tinker --execute="echo 'Testing DB Connection...'; try { DB::connection('sqlsrv')->getPdo(); echo ' ✓ Conexión exitosa'; } catch (\Exception \$e) { echo ' ✗ Error: ' . \$e->getMessage(); }"
    leader_only: true
    ignore_errors: true
