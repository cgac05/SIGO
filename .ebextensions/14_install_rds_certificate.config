# Solución definitiva para SSL: instalar certificado RDS en el sistema
# Problema: ODBC Driver 18 no confía en el certificado autofirmado de RDS
# Solución: Descargar certificado de AWS RDS y agregarlo al CA store

commands:
  01_download_rds_certificate:
    command: |
      echo "=== Descargando certificado RDS ===" > /tmp/rds_cert.log
      
      # Crear directorio para certificados
      mkdir -p /opt/rds-ca
      
      # Descargar el CA bundle de AWS RDS
      cd /opt/rds-ca
      
      echo "Descargando rds-ca-2019-root.pem..." | tee -a /tmp/rds_cert.log
      curl -s https://truststore.pki.rds.amazonaws.com/rds-ca-2019-root.pem -o rds-ca-2019-root.pem 2>&1 | tee -a /tmp/rds_cert.log
      
      if [ -f "rds-ca-2019-root.pem" ] && [ -s "rds-ca-2019-root.pem" ]; then
        echo "✓ Certificado descargado ($(wc -c < rds-ca-2019-root.pem) bytes)" | tee -a /tmp/rds_cert.log
      else
        echo "❌ Fallo al descargar certificado" | tee -a /tmp/rds_cert.log
        exit 1
      fi
      
      # Descargar también el certificado 2024 (más reciente)
      echo "Descargando rds-ca-2024-root.pem (más reciente)..." | tee -a /tmp/rds_cert.log
      curl -s https://truststore.pki.rds.amazonaws.com/rds-ca-2024-root.pem -o rds-ca-2024-root.pem 2>&1 | tee -a /tmp/rds_cert.log || echo "⚠ 2024 no disponible" | tee -a /tmp/rds_cert.log
      
      echo "✓ Certificados descargados en /opt/rds-ca/" | tee -a /tmp/rds_cert.log
      ls -la /opt/rds-ca/ | tee -a /tmp/rds_cert.log
      
      cp /tmp/rds_cert.log /var/app/current/storage/logs/eb_fixes/ 2>/dev/null || true

  02_install_cert_to_system:
    command: |
      echo "=== Instalando certificados en CA store ===" > /tmp/cert_install.log
      
      CERT_DIR="/opt/rds-ca"
      
      # Para CentOS/RHEL/Amazon Linux 2
      if [ -f "/etc/pki/ca-trust/extracted/pem/tls-ca-bundle.pem" ]; then
        echo "Instalando en /etc/pki/ca-trust..." | tee -a /tmp/cert_install.log
        
        cp "$CERT_DIR"/rds-ca-*.pem /etc/pki/tls/certs/ 2>&1 | tee -a /tmp/cert_install.log
        
        # Crear CA bundle combinado
        cat /etc/pki/tls/certs/rds-ca-*.pem >> /etc/pki/ca-trust/extracted/pem/tls-ca-bundle.pem 2>&1 | tee -a /tmp/cert_install.log
        
        update-ca-trust 2>&1 | tee -a /tmp/cert_install.log
        echo "✓ Certificados instalados en CA store" | tee -a /tmp/cert_install.log
      fi
      
      # Para sistemas con /etc/ssl
      if [ -d "/etc/ssl/certs" ]; then
        echo "Copiando a /etc/ssl/certs..." | tee -a /tmp/cert_install.log
        cp "$CERT_DIR"/rds-ca-*.pem /etc/ssl/certs/ 2>&1 | tee -a /tmp/cert_install.log
      fi
      
      echo "✓ Certificados instalados" | tee -a /tmp/cert_install.log
      cp /tmp/cert_install.log /var/app/current/storage/logs/eb_fixes/ 2>/dev/null || true

  03_configure_odbc_with_certificate:
    command: |
      echo "=== Configuración ODBC con certificado ===" > /tmp/odbc_cert_config.log
      
      # Actualizar odbcinst.ini
      cat > /etc/odbcinst.ini << 'EOF'
[ODBC Driver 18 for SQL Server]
Description=Microsoft ODBC Driver 18 for SQL Server
Driver=libodbcsqlsrv.so.18.3
UsageCount=1
EOF
      
      echo "✓ odbcinst.ini actualizado" | tee -a /tmp/odbc_cert_config.log
      
      # Actualizar odbc.ini con ruta al certificado
      cat > /etc/odbc.ini << 'EOF'
[SIGO-RDS]
Driver=ODBC Driver 18 for SQL Server
Server=bdsigoprod.ca7cms0eernu.us-east-1.rds.amazonaws.com,1433
Database=BD_SIGO
Encrypt=yes
TrustServerCertificate=no
CertDir=/etc/ssl/certs
Connection Timeout=30
EOF
      
      echo "✓ odbc.ini configurado" | tee -a /tmp/odbc_cert_config.log
      cat /etc/odbc.ini | tee -a /tmp/odbc_cert_config.log
      
      cp /tmp/odbc_cert_config.log /var/app/current/storage/logs/eb_fixes/ 2>/dev/null || true

  04_configure_laravel_for_ssl:
    command: |
      cd /var/app/current
      
      echo "=== Configuración de Laravel para SSL ===" > /tmp/laravel_ssl.log
      
      # Crear un service provider que configura PDO correctamente
      cat > app/Providers/SqlServerSSLProvider.php << 'PHPEOF'
<?php

namespace App\Providers;

use Illuminate\Support\ServiceProvider;
use PDO;

class SqlServerSSLProvider extends ServiceProvider
{
    public function boot()
    {
        // Configurar opciones por defecto para SQL Server
        if (config('database.default') === 'sqlsrv') {
            // No necesitamos hacer nada especial aquí si los certificados están en el sistema
            \Log::info('SQL Server SSL configuration loaded');
        }
    }
}
PHPEOF

      echo "✓ SqlServerSSLProvider creado" | tee -a /tmp/laravel_ssl.log
      
      # Registrar el provider en config/app.php
      if ! grep -q "SqlServerSSLProvider" config/app.php; then
        sed -i "/App\\\\Providers\\\\RouteServiceProvider::class,/a\        App\\\\Providers\\\\SqlServerSSLProvider::class," config/app.php
        echo "✓ Provider registrado en config/app.php" | tee -a /tmp/laravel_ssl.log
      fi
      
      cp /tmp/laravel_ssl.log /var/app/current/storage/logs/eb_fixes/ 2>/dev/null || true

  05_verify_certificate_chain:
    command: |
      echo "=== Verificación de cadena de certificados ===" > /tmp/cert_verify.log
      
      # Verificar que openssl puede conectar a RDS
      echo "Intentando conexión con openssl..." | tee -a /tmp/cert_verify.log
      
      timeout 10 openssl s_client -connect bdsigoprod.ca7cms0eernu.us-east-1.rds.amazonaws.com:1433 -showcerts 2>&1 | head -50 | tee -a /tmp/cert_verify.log || echo "⚠ openssl timeout o error" | tee -a /tmp/cert_verify.log
      
      # Verificar archivos de certificado
      echo "Certificados en el sistema:" | tee -a /tmp/cert_verify.log
      find /etc/ssl -name "rds-ca*" 2>/dev/null | tee -a /tmp/cert_verify.log
      find /etc/pki -name "rds-ca*" 2>/dev/null | tee -a /tmp/cert_verify.log
      
      cp /tmp/cert_verify.log /var/app/current/storage/logs/eb_fixes/ 2>/dev/null || true

  06_test_odbc_with_certificate:
    command: |
      echo "=== Test ODBC con certificados ===" > /tmp/odbc_cert_test.log
      
      # Crear un script PHP para test
      cat > /tmp/test_pdo_connection.php << 'PHPEOF'
<?php
$serverName = "bdsigoprod.ca7cms0eernu.us-east-1.rds.amazonaws.com,1433";
$database = "BD_SIGO";
$username = "admin";
$password = "vv8StWVd9Rx8JVc?";

try {
    // Opción 1: Conexión básica (confiar en certificado del sistema)
    $connectionString = "sqlsrv:Server=$serverName;Database=$database;Encrypt=yes;TrustServerCertificate=no";
    
    echo "Intentando conexión con certificado del sistema...\n";
    $pdo = new PDO($connectionString, $username, $password);
    
    $result = $pdo->query("SELECT 1 as test");
    $row = $result->fetch();
    
    echo "✓ Conexión EXITOSA\n";
    echo "Test query result: " . json_encode($row) . "\n";
    
} catch (PDOException $e) {
    echo "Conexión fallida, intentando con TrustServerCertificate=yes...\n";
    echo "Error: " . $e->getMessage() . "\n";
    
    try {
        // Opción 2: Confiar en certificado sin verificar (último recurso)
        $connectionString = "sqlsrv:Server=$serverName;Database=$database;Encrypt=yes;TrustServerCertificate=yes";
        echo "Intentando con TrustServerCertificate=yes...\n";
        
        $pdo = new PDO($connectionString, $username, $password);
        $result = $pdo->query("SELECT 1 as test");
        $row = $result->fetch();
        
        echo "✓ Conexión EXITOSA (sin verificación)\n";
        echo "Test query result: " . json_encode($row) . "\n";
        
    } catch (PDOException $e) {
        echo "❌ Ambas opciones fallaron\n";
        echo "Error final: " . $e->getMessage() . "\n";
        exit(1);
    }
}
PHPEOF

      php /tmp/test_pdo_connection.php 2>&1 | tee -a /tmp/odbc_cert_test.log
      
      cp /tmp/odbc_cert_test.log /var/app/current/storage/logs/eb_fixes/ 2>/dev/null || true

  07_update_database_config_final:
    command: |
      cd /var/app/current
      
      echo "=== Actualización final de database.php ===" > /tmp/db_config_final.log
      
      # Verificar y actualizar config/database.php
      php -r "
      \$file = 'config/database.php';
      \$content = file_get_contents(\$file);
      
      // Solo actualizar si no está ya configurado
      if (strpos(\$content, 'TrustServerCertificate') === false) {
          // Agregar configuración de SSL
          \$pattern = \"/'login_timeout' => env\('DB_LOGIN_TIMEOUT', 30\),/\";
          \$replacement = \"'login_timeout' => env('DB_LOGIN_TIMEOUT', 30),\n            'trust_server_certificate' => env('DB_TRUST_SERVER_CERTIFICATE', 'false') === 'false' ? false : true,\";
          
          \$content = preg_replace(\$pattern, \$replacement, \$content);
          
          if (file_put_contents(\$file, \$content)) {
              echo '✓ config/database.php actualizado\\n';
          }
      }
      " 2>&1 | tee -a /tmp/db_config_final.log
      
      cp /tmp/db_config_final.log /var/app/current/storage/logs/eb_fixes/ 2>/dev/null || true

  08_clear_laravel_caches:
    command: |
      cd /var/app/current
      
      echo "=== Limpiar y regenerar caches ===" > /tmp/cache_clear.log
      
      php artisan config:clear 2>&1 | tee -a /tmp/cache_clear.log
      php artisan cache:clear 2>&1 | tee -a /tmp/cache_clear.log
      php artisan config:cache 2>&1 | tee -a /tmp/cache_clear.log
      
      echo "✓ Caches regenerados" | tee -a /tmp/cache_clear.log
      
      cp /tmp/cache_clear.log /var/app/current/storage/logs/eb_fixes/ 2>/dev/null || true

  09_restart_services:
    command: |
      echo "=== Reinicio de servicios ===" > /tmp/restart_services.log
      
      systemctl restart php-fpm 2>&1 | tee -a /tmp/restart_services.log
      systemctl restart nginx 2>&1 | tee -a /tmp/restart_services.log
      
      sleep 2
      
      echo "✓ Servicios reiniciados" | tee -a /tmp/restart_services.log
      
      cp /tmp/restart_services.log /var/app/current/storage/logs/eb_fixes/ 2>/dev/null || true

option_settings:
  aws:elasticbeanstalk:application:environment:
    # Forzar que use certificados del sistema
    SSL_CERT_DIR: "/etc/ssl/certs"
    SSL_CERT_FILE: "/etc/ssl/certs/ca-bundle.crt"
    OPENSSL_CONF: "/etc/ssl/openssl.cnf"
