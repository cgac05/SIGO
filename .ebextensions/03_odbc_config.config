# Configuración adicional de ODBC y validación
files:
  "/etc/odbc.ini":
    mode: "000644"
    owner: root
    group: root
    content: |
      [SQL Server]
      Driver = ODBC Driver 18 for SQL Server
      TrustServerCertificate = yes

container_commands:
  01_test_odbc_connection:
    command: |
      echo "Testing ODBC Driver..."
      ODBC_VERSION=$(odbcinst -j 2>/dev/null | grep ODBC || echo "ODBC not found")
      echo "ODBC Status: $ODBC_VERSION" | tee /tmp/odbc_test.log
      
      # Listar drivers disponibles
      echo "Available ODBC Drivers:" >> /tmp/odbc_test.log
      odbcinst -q -l -d 2>/dev/null >> /tmp/odbc_test.log || echo "ODBC info unavailable" >> /tmp/odbc_test.log
    leader_only: true
    ignore_errors: true
  02_test_db_connectivity:
    command: |
      cd /var/app/current
      
      # Crear script de prueba
      cat > /tmp/test_db.php << 'PHPEOF'
      <?php
      echo "=== Database Connection Test ===\n";
      echo "PHP Version: " . PHP_VERSION . "\n";
      echo "Loaded Extensions:\n";
      
      $extensions = ['sqlsrv', 'pdo_sqlsrv', 'pdo', 'odbc'];
      foreach ($extensions as $ext) {
          echo "  - $ext: " . (extension_loaded($ext) ? "✓ LOADED" : "✗ NOT LOADED") . "\n";
      }
      
      // Intentar conexión
      echo "\nAttempting database connection...\n";
      try {
          if (extension_loaded('pdo_sqlsrv')) {
              $pdo = new PDO(
                  'sqlsrv:Server=' . getenv('DB_HOST') . ';Database=' . getenv('DB_DATABASE'),
                  getenv('DB_USERNAME'),
                  getenv('DB_PASSWORD')
              );
              echo "✓ PDO Connection successful!\n";
              
              $stmt = $pdo->query("SELECT 1 as test");
              $result = $stmt->fetch(PDO::FETCH_ASSOC);
              echo "✓ Query execution successful!\n";
              echo "Result: " . json_encode($result) . "\n";
          } else {
              echo "✗ PDO SQLSrv extension not loaded\n";
          }
      } catch (Exception $e) {
          echo "✗ Connection Error: " . $e->getMessage() . "\n";
      }
      PHPEOF
      
      php /tmp/test_db.php | tee /tmp/db_test_result.log
      cp /tmp/db_test_result.log /var/app/current/storage/logs/db_test.log 2>/dev/null || true
    leader_only: true
    ignore_errors: true
