commands:
  01_nginx_laravel_rewrite:
    command: |
      # Crear configuración de nginx para Laravel
      cat > /etc/nginx/conf.d/01_laravel.conf << 'EOF'
      # Laravel routing configuration for Elastic Beanstalk
      
      # This rewrite rule ensures all requests to non-existent files/dirs
      # are passed to index.php for Laravel routing
      
      location / {
          # First, try to serve the request as a file (for CSS, JS, images, etc)
          try_files $uri $uri/ /index.php$is_args$args;
      }
      
      # Pass .php files to PHP-FPM
      location ~ \.php$ {
          try_files $uri =404;
          fastcgi_pass 127.0.0.1:9000;
          fastcgi_index index.php;
          fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
          include fastcgi_params;
      }
      EOF
      
      echo "✓ Laravel nginx configuration created"

container_commands:
  01_test_reload_nginx:
    command: |
      # Test and reload nginx
      nginx -t 2>&1
      if [ $? -eq 0 ]; then
          systemctl reload nginx 2>/dev/null || service nginx reload 2>/dev/null || true
          echo "✓ Nginx reloaded successfully"
      else
          echo "✗ Nginx configuration test failed"
          exit 1
      fi
