# Instalación robusta de SQL Server drivers - Sin PECL
# Estrategia: Usar drivers precompilados desde Microsoft + binarios de RHEL
files:
  "/etc/yum.repos.d/microsoft-prod.repo":
    mode: "000644"
    owner: root
    group: root
    content: |
      [packages-microsoft-com-prod]
      name=packages-microsoft-com-prod
      baseurl=https://packages.microsoft.com/rhel/9/prod
      enabled=1
      gpgcheck=1
      gpgkey=https://packages.microsoft.com/keys/microsoft.asc

commands:
  00_create_log_dir:
    command: "mkdir -p /var/app/current/storage/logs/eb_install && chmod 777 /var/app/current/storage/logs/eb_install"
    ignoreErrors: true

  01_import_microsoft_key:
    command: "rpm --import https://packages.microsoft.com/keys/microsoft.asc || true"

  02_update_repos:
    command: "dnf check-update || true"

  03_install_odbc_driver:
    command: |
      echo "=== Installing ODBC Driver ===" | tee /tmp/install.log
      ACCEPT_EULA=Y dnf install -y msodbcsql18 2>&1 | tee -a /tmp/install.log
      echo "✓ ODBC Driver installed" | tee -a /tmp/install.log

  04_install_php_sqlsrv_binary:
    command: |
      echo "=== Installing PHP SQL Server Extension (Binary) ===" | tee -a /tmp/install.log
      
      # Detectar versión de PHP
      PHP_VERSION=$(php -v | head -1)
      echo "PHP Version: $PHP_VERSION" | tee -a /tmp/install.log
      
      # Intentar instalar desde dnf (MÁS CONFIABLE que PECL)
      dnf install -y php-sqlsrv php-pdo_sqlsrv 2>&1 | tee -a /tmp/install.log
      RESULT=$?
      
      if [ $RESULT -eq 0 ]; then
        echo "✓ PHP extensions installed successfully" | tee -a /tmp/install.log
      else
        echo "⚠ dnf install failed (code: $RESULT), will attempt PECL as fallback" | tee -a /tmp/install.log
      fi

  05_verify_extensions_exist:
    command: |
      echo "=== Checking for extension files ===" | tee -a /tmp/install.log
      
      EXT_DIR=$(php -r "echo ini_get('extension_dir');")
      echo "Extension directory: $EXT_DIR" | tee -a /tmp/install.log
      
      echo "Looking for sqlsrv.so..." | tee -a /tmp/install.log
      find /usr -name "sqlsrv.so" 2>/dev/null | tee -a /tmp/install.log || echo "  (not found)" | tee -a /tmp/install.log
      
      echo "Looking for pdo_sqlsrv.so..." | tee -a /tmp/install.log
      find /usr -name "pdo_sqlsrv.so" 2>/dev/null | tee -a /tmp/install.log || echo "  (not found)" | tee -a /tmp/install.log

  06_create_php_config:
    command: |
      echo "=== Creating PHP Configuration ===" | tee -a /tmp/install.log
      
      # Crear archivos de configuración para las extensiones
      cat > /etc/php.d/30-sqlsrv.ini << 'PHPINIEOF'
      ; SQL Server extension
      extension=sqlsrv.so
      PHPINIEOF
      
      cat > /etc/php.d/30-pdo_sqlsrv.ini << 'PHPINIEOF'
      ; PDO SQL Server extension
      extension=pdo_sqlsrv.so
      PHPINIEOF
      
      echo "✓ PHP config files created" | tee -a /tmp/install.log
      echo "Contents of /etc/php.d/30-*.ini:" | tee -a /tmp/install.log
      cat /etc/php.d/30-sqlsrv.ini | tee -a /tmp/install.log
      cat /etc/php.d/30-pdo_sqlsrv.ini | tee -a /tmp/install.log

  07_restart_services:
    command: |
      echo "=== Restarting Services ===" | tee -a /tmp/install.log
      
      # Restart PHP-FPM
      if systemctl restart php-fpm 2>&1 | tee -a /tmp/install.log; then
        echo "✓ PHP-FPM restarted" | tee -a /tmp/install.log
      else
        service php-fpm restart 2>&1 | tee -a /tmp/install.log
        echo "✓ PHP-FPM restarted (using service)" | tee -a /tmp/install.log
      fi
      
      # Restart Nginx
      if systemctl restart nginx 2>&1 | tee -a /tmp/install.log; then
        echo "✓ Nginx restarted" | tee -a /tmp/install.log
      else
        service nginx restart 2>&1 | tee -a /tmp/install.log
        echo "✓ Nginx restarted (using service)" | tee -a /tmp/install.log
      fi

  08_final_verification:
    command: |
      echo "" | tee -a /tmp/install.log
      echo "╔════════════════════════════════════════════════╗" | tee -a /tmp/install.log
      echo "║     VERIFICACIÓN FINAL DE DRIVERS             ║" | tee -a /tmp/install.log
      echo "╚════════════════════════════════════════════════╝" | tee -a /tmp/install.log
      echo "" | tee -a /tmp/install.log
      
      echo "PHP Modules:" | tee -a /tmp/install.log
      php -m | grep -i sqlsrv | tee -a /tmp/install.log && echo "  ✓ sqlsrv FOUND" || echo "  ✗ sqlsrv NOT FOUND"
      php -m | grep -i pdo_sqlsrv | tee -a /tmp/install.log && echo "  ✓ pdo_sqlsrv FOUND" || echo "  ✗ pdo_sqlsrv NOT FOUND"
      
      echo "" | tee -a /tmp/install.log
      echo "PHP Version & Info:" | tee -a /tmp/install.log
      php -v | tee -a /tmp/install.log
      
      echo "" | tee -a /tmp/install.log
      echo "Service Status:" | tee -a /tmp/install.log
      systemctl status php-fpm --no-pager 2>&1 | head -5 | tee -a /tmp/install.log
      
      echo "" | tee -a /tmp/install.log
      echo "📋 Full log saved to: /tmp/install.log" | tee -a /tmp/install.log

  09_copy_logs_to_app:
    command: |
      # Copiar logs a la carpeta de la aplicación para persistencia
      mkdir -p /var/app/current/storage/logs/eb_install
      cp /tmp/install.log /var/app/current/storage/logs/eb_install/$(date +%Y%m%d_%H%M%S)_install.log 2>/dev/null || true
      ls -lah /var/app/current/storage/logs/eb_install/ 2>/dev/null || echo "Could not list log directory"

container_commands:
  01_laravel_config_cache:
    command: "cd /var/app/current && php artisan config:cache && php artisan cache:clear"
    leader_only: true
    ignoreErrors: true

  02_test_db_connection:
    command: |
      cd /var/app/current
      
      # Crear script de test
      cat > /tmp/test_sqlserver.php << 'TESTEOF'
      <?php
      echo "╔════════════════════════════════════════════════╗\n";
      echo "║      DATABASE CONNECTION TEST                 ║\n";
      echo "╚════════════════════════════════════════════════╝\n\n";
      
      echo "1. Checking PHP Extensions:\n";
      $extensions = ['sqlsrv', 'pdo_sqlsrv', 'pdo'];
      foreach ($extensions as $ext) {
          $status = extension_loaded($ext) ? "✓ LOADED" : "✗ NOT LOADED";
          echo "   - $ext: $status\n";
      }
      
      echo "\n2. Available PDO Drivers:\n";
      $drivers = PDO::getAvailableDrivers();
      foreach ($drivers as $driver) {
          echo "   - $driver\n";
      }
      
      if (!in_array('sqlsrv', $drivers)) {
          echo "\n❌ CRITICAL: sqlsrv driver not available\n";
          exit(1);
      }
      
      echo "\n3. Connection Test:\n";
      try {
          $host = getenv('DB_HOST');
          $db = getenv('DB_DATABASE');
          $user = getenv('DB_USERNAME');
          $pass = getenv('DB_PASSWORD');
          
          echo "   Host: $host\n";
          echo "   Database: $db\n";
          
          if (!$user) {
              echo "   ⚠️  DB_USERNAME not set\n";
              exit(0);
          }
          
          $dsn = "sqlsrv:Server=$host,1433;Database=$db";
          $pdo = new PDO($dsn, $user, $pass);
          echo "   ✓ Connection successful!\n";
          
          $result = $pdo->query("SELECT 1 as test")->fetch();
          echo "   ✓ Query executed successfully\n";
          
      } catch (Exception $e) {
          echo "   ✗ Error: " . $e->getMessage() . "\n";
      }
      TESTEOF
      
      php /tmp/test_sqlserver.php
      cp /tmp/test_sqlserver.php /var/app/current/storage/logs/eb_install/test_$(date +%s).php 2>/dev/null || true
    leader_only: true
    ignoreErrors: true
