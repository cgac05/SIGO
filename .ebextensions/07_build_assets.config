# Compilar assets (CSS/JS) de Tailwind y Vite después de cada deployment

files:
  # Crear archivo temporal para marcar si la compilación se ejecutó
  "/opt/elasticbeanstalk/hooks/appdeploy/post/asset_build.sh":
    mode: "000755"
    owner: root
    group: root
    content: |
      #!/bin/bash
      set -e
      
      APP_DIR="/var/app/current"
      LOG_DIR="$APP_DIR/storage/logs/eb_fixes"
      LOG_FILE="$LOG_DIR/asset_build.log"
      
      # Crear directorio de logs
      mkdir -p "$LOG_DIR"
      
      echo "=== COMPILACIÓN DE ASSETS ===" | tee "$LOG_FILE"
      echo "Timestamp: $(date)" >> "$LOG_FILE"
      
      # Cambiar al directorio de la aplicación
      cd "$APP_DIR"
      echo "✓ En directorio: $(pwd)" | tee -a "$LOG_FILE"
      
      # Verificar que exista package.json
      if [ ! -f "package.json" ]; then
        echo "❌ package.json no encontrado en $APP_DIR" | tee -a "$LOG_FILE"
        exit 1
      fi
      
      # Instalar dependencias Node.js
      echo "📦 Instalando dependencias Node.js..." | tee -a "$LOG_FILE"
      if npm install 2>&1 | tee -a "$LOG_FILE"; then
        echo "✓ Dependencias instaladas" | tee -a "$LOG_FILE"
      else
        echo "⚠ Advertencia: npm install tuvo problemas" | tee -a "$LOG_FILE"
      fi
      
      # Compilar assets para producción
      echo "🔨 Compilando assets para producción..." | tee -a "$LOG_FILE"
      if npm run build 2>&1 | tee -a "$LOG_FILE"; then
        echo "✓ Assets compilados exitosamente" | tee -a "$LOG_FILE"
        
        # Verificar que se creó build/manifest.json
        if [ -f "public/build/manifest.json" ]; then
          echo "✓ manifest.json creado en public/build/" | tee -a "$LOG_FILE"
          ls -lah public/build/ | tee -a "$LOG_FILE"
        else
          echo "⚠ Advertencia: manifest.json no encontrado después de build" | tee -a "$LOG_FILE"
        fi
      else
        echo "❌ Error: npm run build falló" | tee -a "$LOG_FILE"
        exit 1
      fi
      
      echo "✓ Compilación de assets completada" | tee -a "$LOG_FILE"

option_settings:
  aws:elasticbeanstalk:application:environment:
    NODE_ENV: "production"
