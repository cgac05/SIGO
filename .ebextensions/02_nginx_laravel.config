commands:
  01_configure_laravel_routing:
    command: |
      # Create a minimal nginx configuration override for Laravel
      mkdir -p /etc/nginx/conf.d/elasticbeanstalk
      
      cat > /etc/nginx/conf.d/elasticbeanstalk/laravel.conf << 'EOF'
      # This location block overrides the default Elastic Beanstalk configuration
      # to enable Laravel routing through index.php
      
      location / {
          try_files $uri $uri/ /index.php?$query_string;
      }
      
      location ~ \.php$ {
          try_files $uri =404;
          fastcgi_split_path_info ^(.+\.php)(/.+)$;
          fastcgi_pass unix:/var/run/php-fpm.socket;
          fastcgi_index index.php;
          fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
          include fastcgi_params;
      }
      EOF
      
      # Test and reload nginx
      echo "Testing nginx configuration..."
      nginx -t
      if [ $? -eq 0 ]; then
          systemctl reload nginx 2>/dev/null || service nginx reload 2>/dev/null || true
          echo "✓ Nginx reloaded with Laravel routing configuration"
      else
          echo "✗ Nginx configuration test failed - check /var/log/nginx/error.log"
      fi
