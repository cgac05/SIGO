commands:
  01_nginx_laravel_config:
    command: |
      # Create Laravel routing configuration for nginx
      cat > /tmp/laravel_routing.conf << 'EOFNGINX'
      # Laravel routing configuration
      # This block handles Laravel's routing through index.php
      
      location / {
          if (!-e $request_filename) {
              rewrite ^(.*)$ /index.php?$1 last;
          }
      }
      EOFNGINX
      echo "Nginx Laravel routing config created"

files:
  "/etc/nginx/conf.d/elasticbeanstalk/01_laravel.conf":
    mode: "000644"
    owner: root
    group: root
    content: |
      # Laravel application routing
      location / {
          if (!-e $request_filename) {
              rewrite ^(.*)$ /index.php?$1 last;
          }
      }

container_commands:
  01_reload_nginx:
    command: nginx -s reload 2>/dev/null || systemctl reload nginx || service nginx reload || true
    ignoreErrors: true


