# Actualizar variables .env en EB
# Asegurar que existan todas las variables de conexión SQL Server

commands:
  01_ensure_db_config_variables:
    command: |
      ENV_FILE="/var/app/current/.env"
      
      echo "=== Actualizando .env con variables SQL Server ===" > /tmp/env_config.log
      
      # Verificar que .env existe
      if [ ! -f "$ENV_FILE" ]; then
        echo "❌ .env no encontrado" | tee -a /tmp/env_config.log
        exit 1
      fi
      
      echo "✓ .env encontrado" | tee -a /tmp/env_config.log
      
      # Función para actualizar o agregar variable
      update_or_add_var() {
        VAR_NAME="$1"
        VAR_VALUE="$2"
        
        if grep -q "^${VAR_NAME}=" "$ENV_FILE"; then
          # Variable existe, actualizar
          sed -i "s|^${VAR_NAME}=.*|${VAR_NAME}=${VAR_VALUE}|g" "$ENV_FILE"
          echo "✓ Actualizado: $VAR_NAME" | tee -a /tmp/env_config.log
        else
          # Variable no existe, agregar
          echo "${VAR_NAME}=${VAR_VALUE}" >> "$ENV_FILE"
          echo "✓ Agregado: $VAR_NAME" | tee -a /tmp/env_config.log
        fi
      }
      
      # Asegurar variables de conexión SQL Server
      update_or_add_var "DB_CONNECTION" "sqlsrv"
      update_or_add_var "DB_HOST" "bdsigoprod.ca7cms0eernu.us-east-1.rds.amazonaws.com"
      update_or_add_var "DB_PORT" "1433"
      update_or_add_var "DB_DATABASE" "BD_SIGO"
      update_or_add_var "DB_USERNAME" "admin"
      update_or_add_var "DB_PASSWORD" "vv8StWVd9Rx8JVc?"
      update_or_add_var "DB_ENCRYPT" "yes"
      update_or_add_var "DB_TRUST_SERVER_CERTIFICATE" "true"
      update_or_add_var "DB_LOGIN_TIMEOUT" "30"
      
      # Otras variables importantes
      update_or_add_var "SESSION_DRIVER" "file"
      update_or_add_var "SESSION_LIFETIME" "120"
      
      echo "✓ Configuración completada" | tee -a /tmp/env_config.log

  02_verify_laravel_config:
    command: |
      cd /var/app/current
      
      echo "=== Verificación de Configuración Laravel ===" > /tmp/laravel_config.log
      
      # Clear caches
      php artisan config:clear 2>&1 | tee -a /tmp/laravel_config.log
      php artisan cache:clear 2>&1 | tee -a /tmp/laravel_config.log
      
      # Regenerate caches
      php artisan config:cache 2>&1 | tee -a /tmp/laravel_config.log
      
      echo "✓ Configuración de Laravel actualizada" | tee -a /tmp/laravel_config.log

  03_copy_env_logs:
    command: |
      mkdir -p /var/app/current/storage/logs/eb_fixes
      cp /tmp/env_config.log /var/app/current/storage/logs/eb_fixes/ 2>/dev/null || true
      cp /tmp/laravel_config.log /var/app/current/storage/logs/eb_fixes/ 2>/dev/null || true
