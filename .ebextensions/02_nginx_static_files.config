files:
  "/etc/nginx/conf.d/elasticbeanstalk/01_static.conf":
    mode: "000644"
    owner: root
    group: root
    content: |
      # Servir archivos estáticos directamente desde /public
      location ~* ^/(?:build|images|storage)/(.*)$ {
          access_log off;
          expires 30d;
          add_header Cache-Control "public, max-age=2592000";
          try_files $uri $uri/ =404;
      }

      # Servir archivos de Vite build
      location ~* \.(?:css|js|woff|woff2|eot|ttf|svg)$ {
          access_log off;
          expires 30d;
          add_header Cache-Control "public, max-age=2592000";
          add_header X-Content-Type-Options nosniff;
          add_header X-Frame-Options SAMEORIGIN;
          add_header X-XSS-Protection "1; mode=block";
          try_files $uri $uri/ =404;
      }

      # Reescribir requests a index.php
      location / {
          try_files $uri $uri/ /index.php?$query_string;
      }

container_commands:
  01_reload_nginx:
    command: "systemctl reload nginx"
    ignoreErrors: true
