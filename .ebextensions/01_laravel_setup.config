# 1. Configuración de Nginx para evitar el error 404 en las rutas de Laravel
files:
  "/etc/nginx/conf.d/php_upstream.conf":
    mode: "000644"
    owner: root
    group: root
    content: |
      upstream php_upstream {
          server 127.0.0.1:9000 max_fails=5 fail_timeout=5s;
          keepalive 256;
      }
  
  "/etc/nginx/conf.d/elasticbeanstalk/laravel_locations.conf":
    mode: "000644"
    owner: root
    group: root
    content: |
      # Proxy estático - no necesita PHP
      location ~ ^/(assets|images|css|js|fonts)/ {
          access_log off;
          expires 30d;
      }
      
      # Rechazar archivos sensibles
      location ~ /\. {
          deny all;
          access_log off;
          log_not_found off;
      }
      
      location ~ ~$ {
          deny all;
          access_log off;
          log_not_found off;
      }
      
      # Raíz - enviar a Laravel
      location / {
          try_files $uri $uri/ /index.php?$query_string;
      }
      
      # Procesar archivos .php
      location ~ \.php$ {
          fastcgi_split_path_info ^(.+\.php)(/.+)$;
          fastcgi_pass php_upstream;
          fastcgi_index index.php;
          fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
          fastcgi_param PATH_INFO $fastcgi_path_info;
          include fastcgi_params;
          fastcgi_param HTTPS $https if_not_empty;
          fastcgi_connect_timeout 60;
          fastcgi_send_timeout 300;
          fastcgi_read_timeout 300;
          fastcgi_buffering off;
          fastcgi_buffer_size 128k;
          fastcgi_buffers 256 4k;
      }
  # El bloque de 01_laravel_server.conf ha sido eliminado porque 
  # listen 443 ssl sin ssl_certificate causaba fallo fatal en Nginx


# 2. Instalación de drivers y memoria Swap para SQL Server
commands:
  00_remove_toxic_nginx_config:
    command: |
      echo "Limpiando archivos de configuración de Nginx rotos de despliegues pasados..."
      rm -f /etc/nginx/conf.d/elasticbeanstalk/laravel.conf
      echo "Limpieza completada."
  01_setup_swap:
    command: |
      if [ ! -f /var/swapfile ]; then
        dd if=/dev/zero of=/var/swapfile bs=1M count=1024
        chmod 600 /var/swapfile
        mkswap /var/swapfile
        swapon /var/swapfile
      fi
  02_install_mssql_repo:
    command: "curl https://packages.microsoft.com/config/rhel/9/prod.repo > /etc/yum.repos.d/mssql-release.repo"
  03_install_dependencies:
    command: |
      ACCEPT_EULA=Y dnf install -y msodbcsql18 unixODBC-devel 2>&1 | tee /tmp/install_deps.log
      dnf install -y php-devel php-pear gcc-c++ make 2>&1 | tee -a /tmp/install_deps.log
  04_install_drivers_method1:
    # Intentar primero con paquetes binarios (MÁS CONFIABLE)
    command: |
      ACCEPT_EULA=Y dnf install -y php-sqlsrv php-pdo_sqlsrv 2>&1 | tee /tmp/dnf_drivers.log || echo "Drivers binarios no disponibles, usaremos PECL"
  04b_install_drivers_method2_pecl:
    # Si los binarios no funcionan, usar PECL
    command: |
      # Verificar si los drivers ya están instalados
      if php -m | grep -q sqlsrv; then
        echo "✓ Drivers ya instalados"
      else
        echo "⚠ Intentando instalar con PECL..."
        pecl channel-update pecl.php.net 2>&1 | tee /tmp/pecl_channel.log
        
        # Detectar versión de PHP
        PHP_VERSION=$(php -r 'echo PHP_MAJOR_VERSION . "." . PHP_MINOR_VERSION;')
        echo "Versión PHP detectada: $PHP_VERSION"
        
        # Instalar drivers PECL
        printf "\n" | pecl install -f sqlsrv 2>&1 | tee /tmp/sqlsrv_install.log
        printf "\n" | pecl install -f pdo_sqlsrv 2>&1 | tee /tmp/pdo_sqlsrv_install.log
      fi
  05_enable_drivers:
    command: |
      # Solo crear los archivos si los drivers no están ya auto-cargados
      if ! grep -q "extension=.*sqlsrv" /etc/php.ini 2>/dev/null; then
        echo "extension=sqlsrv.so" > /etc/php.d/30-sqlsrv.ini
      fi
      if ! grep -q "extension=.*pdo_sqlsrv" /etc/php.ini 2>/dev/null; then
        echo "extension=pdo_sqlsrv.so" > /etc/php.d/30-pdo_sqlsrv.ini
      fi
      echo "✓ Drivers habilitados"
  06_restart_php_and_nginx:
    command: |
      # Reiniciar servicios con validación
      if systemctl restart php-fpm 2>&1 | tee /tmp/php_restart.log; then
        echo "✓ PHP-FPM reiniciado"
      else
        echo "⚠ php-fpm no disponible, intentando service..."
        service php-fpm restart 2>&1 | tee /tmp/php_restart.log || true
      fi
      
      if systemctl restart nginx 2>&1 | tee /tmp/nginx_restart.log; then
        echo "✓ Nginx reiniciado"
      else
        echo "⚠ nginx no disponible"
      fi
  07_verify_installation:
    command: |
      echo "=== VERIFICACIÓN DE DRIVERS ===" > /tmp/verification.log
      
      echo "Módulos PHP cargados:" >> /tmp/verification.log
      php -m | grep -i sqlsrv >> /tmp/verification.log 2>&1 || echo "❌ sqlsrv no encontrado" >> /tmp/verification.log
      php -m | grep -i pdo_sqlsrv >> /tmp/verification.log 2>&1 || echo "❌ pdo_sqlsrv no encontrado" >> /tmp/verification.log
      
      echo "Archivos INI:" >> /tmp/verification.log
      ls -la /etc/php.d/30-*.ini >> /tmp/verification.log 2>&1
      
      echo "Estado de servicios:" >> /tmp/verification.log
      systemctl status php-fpm >> /tmp/verification.log 2>&1 || service php-fpm status >> /tmp/verification.log 2>&1
      systemctl status nginx >> /tmp/verification.log 2>&1 || service nginx status >> /tmp/verification.log 2>&1
      
      cat /tmp/verification.log
      cp /tmp/verification.log /var/app/current/storage/logs/eb_verification.log 2>/dev/null || true
  08_validate_nginx_config:
    command: |
      echo "=== VALIDACIÓN NGINX ===" > /tmp/nginx_validation.log
      
      # Validar sintaxis de Nginx
      if nginx -t 2>&1 | tee -a /tmp/nginx_validation.log; then
        echo "✓ Configuración de Nginx válida"
      else
        echo "❌ Error en configuración de Nginx"
        cat /tmp/nginx_validation.log
        exit 1
      fi
      
      # Verificar archivos de configuración
      echo "Archivos de configuración Nginx:" >> /tmp/nginx_validation.log
      ls -la /etc/nginx/conf.d/*.conf >> /tmp/nginx_validation.log 2>&1
      
      # Mostrar server blocks activos
      echo "=== SERVER BLOCKS ===" >> /tmp/nginx_validation.log
      grep -r "server {" /etc/nginx/conf.d/ >> /tmp/nginx_validation.log 2>&1
      
      cp /tmp/nginx_validation.log /var/app/current/storage/logs/nginx_validation.log 2>/dev/null || true
  09_add_laravel_locations_to_nginx:
    command: |
      # Buscar el archivo de configuración del servidor EB
      NGINX_CONF=$(find /etc/nginx -name "*.conf" -type f | xargs grep -l "server {" | grep -v "php_upstream\|laravel" | head -1)
      
      if [ -z "$NGINX_CONF" ]; then
        echo "⚠ No se encontró server block de Nginx, creando default en 01_laravel_server.conf"
        NGINX_CONF="/etc/nginx/conf.d/01_laravel_server.conf"
      else
        echo "✓ Encontrado server block en: $NGINX_CONF"
      fi
      
      # Solo si no hemos modificado ya
      if ! grep -q "try_files.*index.php" "$NGINX_CONF"; then
        echo "Agregando configuración Laravel a Nginx..."
        
        # Hacer backup
        cp "$NGINX_CONF" "${NGINX_CONF}.backup"
        
        # Insertar las locations antes del cierre del server block
        sed -i '/^[[:space:]]*}[[:space:]]*$/i\
\
    # Proxy estático\
    location ~ ^/(assets|images|css|js|fonts)/ {\
        access_log off;\
        expires 30d;\
    }\
\
    # Rechazar archivos sensibles\
    location ~ /\\. {\
        deny all;\
        access_log off;\
        log_not_found off;\
    }\
\
    # Raíz - enviar a Laravel\
    location / {\
        try_files $uri $uri/ /index.php?$query_string;\
    }\
\
    # Procesar .php\
    location ~ \\.php$ {\
        fastcgi_split_path_info ^(.+\\.php)(/.\+)$;\
        fastcgi_pass 127.0.0.1:9000;\
        fastcgi_index index.php;\
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;\
        fastcgi_param PATH_INFO $fastcgi_path_info;\
        include fastcgi_params;\
        fastcgi_param HTTPS $https if_not_empty;\
        fastcgi_connect_timeout 60;\
        fastcgi_send_timeout 300;\
        fastcgi_read_timeout 300;\
    }' "$NGINX_CONF"
        
        echo "✓ Configuración agregada a Nginx"
      else
        echo "✓ Configuración Laravel ya existe en Nginx"
      fi
  10_reload_nginx:
    command: |
      # Validar antes de recargar
      if nginx -t 2>&1 | tee /tmp/nginx_test.log; then
        echo "✓ Configuración válida, recargando Nginx..."
        if systemctl reload nginx 2>&1; then
          echo "✓ Nginx recargado exitosamente"
        else
          echo "⚠ Reload falló, intentando restart..."
          systemctl restart nginx 2>&1 || service nginx restart 2>&1
        fi
      else
        echo "❌ Error en configuración de Nginx"
        cat /tmp/nginx_test.log
        echo "Revirtiendo cambios desde backup..."
        find /etc/nginx -name "*.conf.backup" -exec sh -c 'mv "$1" "${1%.backup}"' _ {} \;
        systemctl restart nginx
        exit 1
      fi