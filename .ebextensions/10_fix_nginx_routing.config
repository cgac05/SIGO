# Fix específico para enrutamiento de Nginx en Laravel
# Problema: /login y /register retornan 404
# Causa: try_files no se está ejecutando o está mal configurado

files:
  # Crear configuración limpia y simple para Laravel en Nginx
  "/etc/nginx/conf.d/elasticbeanstalk/laravel.conf":
    mode: "000644"
    owner: root
    group: root
    content: |
      # Upstream a PHP-FPM
      upstream php_fpm {
          server 127.0.0.1:9000 max_fails=3 fail_timeout=5s;
          keepalive 256;
      }

      # Bloque de configuración para rutas de Laravel
      # Este archivo se incluye dentro del server block principal de EB
      
      # Rechazar acceso a archivos ocultos
      location ~ /\. {
          deny all;
          access_log off;
          log_not_found off;
      }

      # Recursos estáticos con expiración
      location ~* \.(jpg|jpeg|png|gif|ico|css|js|svg|woff|woff2|ttf|eot)$ {
          expires 30d;
          add_header Cache-Control "public, immutable";
          access_log off;
      }

      # Cualquier URL no existente -> enviar a index.php
      location / {
          try_files $uri $uri/ /index.php?$query_string;
      }

      # Procesar archivos PHP
      location ~ \.php$ {
          # Evitar procesamiento de archivos fuera de /var/app/current
          if (!-f $request_filename) {
              return 404;
          }

          fastcgi_split_path_info ^(.+\.php)(/.+)$;
          fastcgi_pass php_fpm;
          fastcgi_index index.php;

          fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
          fastcgi_param PATH_INFO $fastcgi_path_info;
          fastcgi_param PATH_TRANSLATED $document_root$fastcgi_path_info;

          include fastcgi_params;

          # Headers para Laravel
          fastcgi_param HTTPS $https if_not_empty;
          fastcgi_param SERVER_SOFTWARE nginx/$nginx_version;

          # Timeouts
          fastcgi_connect_timeout 60s;
          fastcgi_send_timeout 300s;
          fastcgi_read_timeout 300s;
          fastcgi_buffering off;
          fastcgi_buffer_size 128k;
          fastcgi_buffers 256 4k;
      }

commands:
  01_verify_nginx_include:
    command: |
      echo "=== Verificación de includes de Nginx ===" > /tmp/nginx_includes.log
      
      # Buscar main nginx config
      NGINX_MAIN="/etc/nginx/nginx.conf"
      if [ ! -f "$NGINX_MAIN" ]; then
        echo "❌ nginx.conf no encontrado" | tee -a /tmp/nginx_includes.log
        exit 1
      fi
      
      echo "✓ nginx.conf encontrado" | tee -a /tmp/nginx_includes.log
      echo "Contenido relevante:" >> /tmp/nginx_includes.log
      grep -A 10 "http {" "$NGINX_MAIN" | head -20 >> /tmp/nginx_includes.log
      grep "include" "$NGINX_MAIN" >> /tmp/nginx_includes.log
      
      # Buscar conf.d
      if [ -d "/etc/nginx/conf.d" ]; then
        echo "✓ /etc/nginx/conf.d existe" | tee -a /tmp/nginx_includes.log
        echo "Archivos en conf.d:" >> /tmp/nginx_includes.log
        ls -la /etc/nginx/conf.d/ >> /tmp/nginx_includes.log
      else
        echo "❌ /etc/nginx/conf.d no existe" | tee -a /tmp/nginx_includes.log
      fi

  02_check_server_block:
    command: |
      echo "=== Búsqueda de Server Block ===" > /tmp/server_block.log
      
      # Buscar dónde está configurado el server block
      SERVER_BLOCK_FILE=$(find /etc/nginx -name "*.conf" -type f -exec grep -l "server {" {} \; | grep -v "upstream\|laravel" | head -1)
      
      if [ -z "$SERVER_BLOCK_FILE" ]; then
        echo "⚠ No se encontró server block, probablemente esté en nginx.conf o conf.d" | tee -a /tmp/server_block.log
        SERVER_BLOCK_FILE="/etc/nginx/nginx.conf"
      else
        echo "✓ Server block encontrado en: $SERVER_BLOCK_FILE" | tee -a /tmp/server_block.log
      fi
      
      echo "Contenido del server block:" >> /tmp/server_block.log
      grep -B 5 -A 30 "server {" "$SERVER_BLOCK_FILE" | head -50 >> /tmp/server_block.log
      
      echo "$SERVER_BLOCK_FILE" > /tmp/server_block_path.txt

  03_validate_nginx_syntax:
    command: |
      echo "=== Validación de Sintaxis Nginx ===" > /tmp/nginx_syntax_test.log
      
      if nginx -t 2>&1 | tee -a /tmp/nginx_syntax_test.log; then
        echo "✓ Sintaxis de Nginx válida" | tee -a /tmp/nginx_syntax_test.log
      else
        echo "❌ Errores en sintaxis de Nginx" | tee -a /tmp/nginx_syntax_test.log
        exit 1
      fi

  04_test_routing:
    command: |
      echo "=== Test de Enrutamiento ===" > /tmp/nginx_routing_test.log
      
      # Crear archivos temporales para simular rutas
      mkdir -p /var/app/current/public/test_dir
      
      echo "Test Laravel routing" > /var/app/current/public/test_dir/test.txt
      
      # Verificar que los archivos existen
      if [ -f "/var/app/current/public/index.php" ]; then
        echo "✓ index.php existe" | tee -a /tmp/nginx_routing_test.log
      else
        echo "❌ index.php no encontrado" | tee -a /tmp/nginx_routing_test.log
      fi
      
      echo "✓ Pruebas de enrutamiento completadas" | tee -a /tmp/nginx_routing_test.log

  05_reload_nginx:
    command: |
      echo "=== Recarga de Nginx ===" > /tmp/nginx_reload.log
      
      # Asegurarse de que la sintaxis es correcta
      if ! nginx -t 2>&1 | tee -a /tmp/nginx_reload.log; then
        echo "❌ Errores en configuración, no se puede recargar" | tee -a /tmp/nginx_reload.log
        exit 1
      fi
      
      # Recargar (no restart) para mantener conexiones activas
      if systemctl reload nginx 2>&1 | tee -a /tmp/nginx_reload.log; then
        echo "✓ Nginx recargado exitosamente" | tee -a /tmp/nginx_reload.log
      else
        echo "⚠ Reload falló, intentando restart..." | tee -a /tmp/nginx_reload.log
        systemctl restart nginx 2>&1 | tee -a /tmp/nginx_reload.log || service nginx restart 2>&1 | tee -a /tmp/nginx_reload.log
      fi

container_commands:
  01_copy_logs:
    command: |
      mkdir -p /var/app/current/storage/logs/eb_fixes
      cp /tmp/nginx_includes.log /var/app/current/storage/logs/eb_fixes/ 2>/dev/null || true
      cp /tmp/server_block.log /var/app/current/storage/logs/eb_fixes/ 2>/dev/null || true
      cp /tmp/nginx_syntax_test.log /var/app/current/storage/logs/eb_fixes/ 2>/dev/null || true
      cp /tmp/nginx_routing_test.log /var/app/current/storage/logs/eb_fixes/ 2>/dev/null || true
      cp /tmp/nginx_reload.log /var/app/current/storage/logs/eb_fixes/ 2>/dev/null || true
